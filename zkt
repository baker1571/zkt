#!/usr/bin/env bash

BASE_DIR="${1:-.}"

if [[ ! -d "$BASE_DIR" ]]; then
    echo "Error: $BASE_DIR is not a directory"
    exit 1
fi

tput clear
trap 'tput clear; exit' EXIT

declare -A files_by_id
declare -A references
declare -a menu_files
declare -a menu_labels
declare -a menu_colors
declare -A printed

cursor=0
scroll=0
count=0

header=(
"  ____      __  __      ____            __          "
" /_  / ___ / /_/ /____ / / /_____  ___ / /____ ___  "
"  / /_/ -_) __/ __/ -_) /  '_/ _ \(_-</ __/ -_) _ \ "
" /___/\__/\__/\__/\__/_/_/\_\\\_,_/___/\__/\__/_//_/ "
""
"Navigate: j/k move | Enter open | l lit-note | p perm-note | r refresh | q quit"
""
)

build_tree() {
    local current_id="$1"
    local indent="$2"

    name=$(basename "${files_by_id[$current_id]}")

    menu_files+=("${files_by_id[$current_id]}")
    menu_labels+=("${indent}${name}")
    menu_colors+=("normal")

    for linked_id in ${references[$current_id]}; do
        if [[ -n "${files_by_id[$linked_id]}" ]]; then
            if [[ -z "${printed[$linked_id]}" ]]; then
                printed["$linked_id"]=1
                build_tree "$linked_id" "  $indent"
            else
                menu_files+=("${files_by_id[$linked_id]}")
                menu_labels+=("  ${indent}$(basename "${files_by_id[$linked_id]}")")
                menu_colors+=("red")
            fi
        fi
    done
}

refresh_menu() {
    unset files_by_id references printed
    declare -gA files_by_id references printed

    menu_files=()
    menu_labels=()
    menu_colors=()

    while IFS= read -r file; do
        filename=$(basename "$file")
        id="${filename:0:14}"
        [[ "$id" =~ ^[0-9]{14}$ ]] && files_by_id["$id"]="$file"
    done < <(find "$BASE_DIR" -type f -name "*.md")

    for id in "${!files_by_id[@]}"; do
        file="${files_by_id[$id]}"
        linked_ids=$(grep -oE '\b[0-9]{14}\b' "$file" | grep -v "^$id$" | sort -u)
        [[ -n "$linked_ids" ]] && references["$id"]="$linked_ids"
    done

    for id in "${!files_by_id[@]}"; do
        is_root=true
        for refs in "${references[@]}"; do
            if grep -q "$id" <<< "$refs"; then
                is_root=false
                break
            fi
        done
        if $is_root; then
            printed["$id"]=1
            build_tree "$id" ""
        fi
    done

    count=${#menu_labels[@]}
    ((cursor >= count)) && cursor=$((count-1))
}

draw_menu() {
    rows=$(tput lines)
    header_lines=${#header[@]}
    menu_height=$((rows - header_lines))
    ((menu_height < 1)) && menu_height=1

    if ((cursor < scroll)); then scroll=$cursor; fi
    if ((cursor >= scroll + menu_height)); then scroll=$((cursor - menu_height + 1)); fi

    tput clear

    for line in "${header[@]}"; do
        echo "$line"
    done

    for ((i=scroll; i<scroll+menu_height && i<count; i++)); do
        label="${menu_labels[$i]}"
        [[ ${menu_colors[$i]} == "red" ]] && label="\033[31m${label}\033[0m"
        if [[ $i -eq $cursor ]]; then
            printf "\e[7m%b\e[0m\n" "$label"
        else
            printf "%b\n" "$label"
        fi
    done
}

open_file() {
    file="${menu_files[$cursor]}"
    "${EDITOR:-vim}" "$file"
    refresh_menu
}

refresh_menu

while true; do
    draw_menu
    read -rsn1 key
    case "$key" in
        k) ((cursor--)); ((cursor<0)) && cursor=$((count-1)) ;;
        j) ((cursor++)); ((cursor>=count)) && cursor=0 ;;
        "") open_file ;;
        l)
            tput clear
            read -rp "Title: " title
            [[ -z "$title" ]] && continue
            ts=$(date +%Y%m%d%H%M%S)
            d=$(date +%Y-%m-%d)
            slug=${title// /_}
            file="$BASE_DIR/${ts}_L_${slug}.md"
            cat > "$file" <<EOF
---
title: $title
id: $ts
date: $d
source:
	title:
	author:
type:
tags:
  -
---
EOF
            "${EDITOR:-nvim}" +13 "$file"
            refresh_menu
            ;;
        p)
            tput clear
            read -rp "Title: " title
            [[ -z "$title" ]] && continue
            ts=$(date +%Y%m%d%H%M%S)
            d=$(date +%Y-%m-%d)
            slug=${title// /_}
            file="$BASE_DIR/${ts}_${slug}.md"
            cat > "$file" <<EOF
---
title: $title
id: $ts
date: $d
type:
tags:
  -
---
EOF
            "${EDITOR:-nvim}" +10 "$file"
            refresh_menu
            ;;
        r) refresh_menu ;;
        q) exit ;;
    esac
done
